generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ============================================
// User & Authentication Models
// ============================================

model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  phone         String?  @unique
  passwordHash  String?  @map("password_hash")
  name          String
  avatarUrl     String?  @map("avatar_url")
  authProvider  String   @default("EMAIL") @map("auth_provider")
  role          String   @default("USER") // USER, ADMIN
  status        String   @default("PENDING")
  mfaEnabled    Boolean  @default(false) @map("mfa_enabled")
  mfaSecret     String?  @map("mfa_secret")
  emailVerified Boolean  @default(false) @map("email_verified")
  phoneVerified Boolean  @default(false) @map("phone_verified")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  profile             UserProfile?
  subscription        Subscription?
  contents            Content[]
  platformConnections PlatformConnection[]
  creditTransactions  CreditTransaction[]
  refreshTokens       RefreshToken[]
  payments            Payment[]
  workspace           Workspace?
  adCampaigns         AdCampaign[]
  leads               Lead[]
  emailLists          EmailList[]
  emailContacts       EmailContact[]
  emailCampaigns      EmailCampaign[]
  emailSequences      EmailSequence[]
  designs             Design[]
  videoProjects       VideoProject[]
  analyticsSnapshots  AnalyticsSnapshot[]

  @@map("users")
}

model UserProfile {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  businessName     String?  @map("business_name")
  industry         String?
  subIndustry      String?  @map("sub_industry")
  description      String?
  mission          String?  // Company mission statement
  vision           String?  // Company vision
  foundedYear      Int?     @map("founded_year")
  employeeCount    String?  @map("employee_count") // "1-10", "11-50", "51-200", etc.
  annualRevenue    String?  @map("annual_revenue") // Revenue range
  businessModel    String?  @map("business_model") // B2B, B2C, B2B2C, etc.

  // Legacy fields (kept for backward compatibility)
  services         String   @default("[]")
  products         String   @default("[]")
  competitors      String   @default("[]")

  // Location & Contact
  targetAudience   String?  @map("target_audience")
  location         String?
  country          String?
  city             String?
  timezone         String   @default("UTC")
  website          String?
  socialLinks      String   @default("{}") @map("social_links") // JSON: {facebook, instagram, linkedin, etc.}

  // Branding - Basic
  logoUrl          String?  @map("logo_url")
  brandColors      String?  @map("brand_colors")
  brandVoice       String?  @map("brand_voice") // e.g., "professional", "friendly", "bold"
  tonePreference   String   @default("professional") @map("tone_preference")
  toneAttributes   String   @default("[]") @map("tone_attributes") // JSON array: ["Confident", "Empathetic", etc.]
  formality        String?  // "very_formal", "formal", "neutral", "casual", "very_casual"
  communicationStyle String? @map("communication_style")

  // Brand Personality
  brandPersonality String?  @map("brand_personality") // Free-text description
  brandArchetype   String?  @map("brand_archetype") // "hero", "creator", "sage", etc.
  personalityTraits String  @default("[]") @map("personality_traits") // JSON array

  // Messaging
  tagline          String?  // Brand tagline/slogan
  elevatorPitch    String?  @map("elevator_pitch") // 30-60 second pitch
  keyMessages      String   @default("[]") @map("key_messages") // JSON array of core messages

  // Content Guidelines
  writingStyle     String?  @map("writing_style") // "concise", "detailed", "storytelling", etc.
  contentThemes    String   @default("[]") @map("content_themes") // JSON array of themes
  topicsToAvoid    String   @default("[]") @map("topics_to_avoid") // JSON array
  brandKeywords    String   @default("[]") @map("brand_keywords") // Keywords that define the brand
  phraseExamples   String   @default("[]") @map("phrase_examples") // JSON array of example phrases

  // Brand Do's and Don'ts
  brandDos         String   @default("[]") @map("brand_dos") // JSON array
  brandDonts       String   @default("[]") @map("brand_donts") // JSON array

  // Visual Identity (descriptions for AI understanding)
  primaryColors    String?  @map("primary_colors") // e.g., "Deep blue (#1a365d), White"
  secondaryColors  String?  @map("secondary_colors")
  fontStyle        String?  @map("font_style") // e.g., "Modern sans-serif"
  visualStyle      String?  @map("visual_style") // "Minimalist", "Bold & Vibrant", etc.

  // Market Position
  uniqueSellingPoints String @default("[]") @map("unique_selling_points") // JSON array of USPs
  valueProposition    String? @map("value_proposition")
  marketPosition      String? @map("market_position") // "Leader", "Challenger", "Niche", etc.
  pricingStrategy     String? @map("pricing_strategy") // "Premium", "Value", "Competitive", etc.

  completeness     Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessProducts BusinessProduct[]
  businessServices BusinessService[]
  businessCompetitors BusinessCompetitor[]
  targetAudiences  TargetAudience[]

  @@map("user_profiles")
}

// ============================================
// Business Products Model
// ============================================

model BusinessProduct {
  id               String   @id @default(uuid())
  profileId        String   @map("profile_id")
  name             String
  slug             String?
  description      String?
  shortDescription String?  @map("short_description")
  category         String?
  subCategory      String?  @map("sub_category")

  // Pricing
  priceType        String   @default("FIXED") @map("price_type") // FIXED, RANGE, CUSTOM, FREE
  price            Float?
  priceMin         Float?   @map("price_min")
  priceMax         Float?   @map("price_max")
  currency         String   @default("USD")
  pricingModel     String?  @map("pricing_model") // "One-time", "Subscription", "Per-user", etc.

  // Details
  features         String   @default("[]") // JSON array of features
  benefits         String   @default("[]") // JSON array of benefits
  specifications   String   @default("{}") // JSON object of specs
  images           String   @default("[]") // JSON array of image URLs

  // Target
  targetMarket     String?  @map("target_market")
  idealCustomer    String?  @map("ideal_customer")
  useCases         String   @default("[]") @map("use_cases") // JSON array

  // Competitive
  competitors      String   @default("[]") // JSON array of competitor product names
  differentiators  String   @default("[]") // JSON array of what makes this unique

  // SEO & Marketing
  keywords         String   @default("[]") // JSON array of keywords
  hashtags         String   @default("[]") // JSON array of hashtags

  isActive         Boolean  @default(true) @map("is_active")
  isFeatured       Boolean  @default(false) @map("is_featured")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  profile          UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, slug])
  @@index([profileId, isActive])
  @@map("business_products")
}

// ============================================
// Business Services Model
// ============================================

model BusinessService {
  id               String   @id @default(uuid())
  profileId        String   @map("profile_id")
  name             String
  slug             String?
  description      String?
  shortDescription String?  @map("short_description")
  category         String?

  // Pricing
  priceType        String   @default("CUSTOM") @map("price_type") // FIXED, HOURLY, RETAINER, RANGE, CUSTOM
  price            Float?
  priceMin         Float?   @map("price_min")
  priceMax         Float?   @map("price_max")
  currency         String   @default("USD")
  pricingUnit      String?  @map("pricing_unit") // "Per Hour", "Per Day", "Per Project", etc.
  billingFrequency String?  @map("billing_frequency") // "One-time", "Monthly", "Quarterly", etc.

  // Details
  deliverables     String   @default("[]") // JSON array of deliverables
  process          String   @default("[]") // JSON array of process steps
  requirements     String   @default("[]") // JSON array - what client needs to provide
  benefits         String   @default("[]") // JSON array of benefits
  duration         String?  // Typical duration

  // Target
  targetMarket     String?  @map("target_market")
  idealClient      String?  @map("ideal_client")
  industries       String   @default("[]") // JSON array of target industries

  // Competitive
  competitors      String   @default("[]") // JSON array of competitor service names
  differentiators  String   @default("[]") // JSON array

  // SEO & Marketing
  keywords         String   @default("[]")
  hashtags         String   @default("[]")

  isActive         Boolean  @default(true) @map("is_active")
  isFeatured       Boolean  @default(false) @map("is_featured")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  profile          UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, slug])
  @@index([profileId, isActive])
  @@map("business_services")
}

// ============================================
// Business Competitors Model
// ============================================

model BusinessCompetitor {
  id               String   @id @default(uuid())
  profileId        String   @map("profile_id")
  name             String
  website          String?
  description      String?
  industry         String?
  size             String?  // Company size
  founded          String?  // Founded year
  headquarters     String?

  // Social Presence
  facebookUrl      String?  @map("facebook_url")
  instagramUrl     String?  @map("instagram_url")
  twitterUrl       String?  @map("twitter_url")
  linkedinUrl      String?  @map("linkedin_url")
  youtubeUrl       String?  @map("youtube_url")
  tiktokUrl        String?  @map("tiktok_url")

  // Market Info
  marketPosition   String?  @map("market_position") // "Direct", "Indirect", "Potential"
  marketShare      String?  @map("market_share") // Estimated market share
  pricePosition    String?  @map("price_position") // "Budget", "Value", "Premium", etc.
  targetAudience   String?  @map("target_audience")
  pricingStrategy  String?  @map("pricing_strategy")

  // SWOT Analysis
  strengths        String   @default("[]") // JSON array
  weaknesses       String   @default("[]") // JSON array
  opportunities    String   @default("[]") // JSON array (for you)
  threats          String   @default("[]") // JSON array (to you)

  // Products & Services
  products         String   @default("[]") // JSON array
  services         String   @default("[]") // JSON array
  uniqueFeatures   String   @default("[]") @map("unique_features") // JSON array

  // Content & Ads Strategy
  contentStrategy  String?  @map("content_strategy") // Description of their content approach
  adPlatforms      String   @default("[]") @map("ad_platforms") // JSON: ["Facebook", "Google", etc.]
  adStrategies     String   @default("[]") @map("ad_strategies") // JSON array of observed strategies
  adBudgetEstimate String?  @map("ad_budget_estimate") // Estimated ad spend
  topPerformingAds String?  @map("top_performing_ads") // Notes on best ads
  contentTypes     String   @default("[]") @map("content_types") // JSON array
  postingFrequency String?  @map("posting_frequency") // How often they post
  engagementLevel  String?  @map("engagement_level") // "Very Low" to "Very High"

  // Performance (estimated/observed)
  socialFollowers  String   @default("{}") @map("social_followers") // JSON: {facebook: 10000, etc.}
  engagementRate   Float?   @map("engagement_rate")

  // Threat level & notes
  threatLevel      String   @default("MEDIUM") @map("threat_level") // LOW, MEDIUM, HIGH
  notes            String?  // Additional notes
  isActive         Boolean  @default(true) @map("is_active")
  lastAnalyzedAt   DateTime? @map("last_analyzed_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  profile          UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isActive])
  @@map("business_competitors")
}

// ============================================
// Target Audience Model
// ============================================

model TargetAudience {
  id               String   @id @default(uuid())
  profileId        String   @map("profile_id")
  name             String   // Persona name, e.g., "Tech-Savvy Millennials"
  description      String?
  isPrimary        Boolean  @default(false) @map("is_primary")

  // Demographics
  ageMin           Int?     @map("age_min")
  ageMax           Int?     @map("age_max")
  gender           String?  // "Male", "Female", "All", "Non-binary"
  incomeLevel      String?  @map("income_level") // "Low", "Middle", "Upper-Middle", "High"
  educationLevel   String?  @map("education_level")
  occupation       String?
  location         String?  // Single location field
  jobTitles        String   @default("[]") @map("job_titles") // JSON array for B2B
  industries       String   @default("[]") // JSON array for B2B
  companySize      String?  @map("company_size") // For B2B

  // Location (multiple)
  locations        String   @default("[]") // JSON array of target locations
  languages        String   @default("[]") // JSON array of languages

  // Psychographics
  interests        String   @default("[]") // JSON array
  hobbies          String   @default("[]") // JSON array
  values           String   @default("[]") // JSON array (what they value)
  lifestyle        String?  // Description of lifestyle
  personality      String?  // Personality traits

  // Behavior
  buyingBehavior   String?  @map("buying_behavior") // Description
  buyingFrequency  String?  @map("buying_frequency") // "Daily", "Weekly", etc.
  avgOrderValue    String?  @map("avg_order_value") // e.g., "$50-100"
  decisionFactors  String   @default("[]") @map("decision_factors") // JSON array
  purchaseFrequency String? @map("purchase_frequency")
  preferredChannels String  @default("[]") @map("preferred_channels") // JSON array
  deviceUsage      String   @default("[]") @map("device_usage") // JSON array

  // Pain Points & Goals
  painPoints       String   @default("[]") @map("pain_points") // JSON array
  goals            String   @default("[]") // JSON array
  challenges       String   @default("[]") // JSON array
  motivations      String   @default("[]") // JSON array
  objections       String   @default("[]") // JSON array (common objections to buying)

  // Content Preferences
  contentPreferences String @default("[]") @map("content_preferences") // JSON: ["Video", "Blog", etc.]
  contentFormats   String   @default("[]") @map("content_formats") // JSON array
  socialPlatforms  String   @default("[]") @map("social_platforms") // JSON array
  bestPostingTimes String   @default("{}") @map("best_posting_times") // JSON object
  communicationStyle String? @map("communication_style")

  // Messaging
  messagingTone    String?  @map("messaging_tone")
  keyMessages      String   @default("[]") @map("key_messages") // JSON array
  avoidTopics      String   @default("[]") @map("avoid_topics") // JSON array

  notes            String?  // Additional notes
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  profile          UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isActive])
  @@map("target_audiences")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================
// Subscription Plans (Admin-managed)
// ============================================

model SubscriptionPlan {
  id                  String   @id @default(uuid())
  name                String   @unique // STARTER, PROFESSIONAL, BUSINESS, ENTERPRISE
  displayName         String   @map("display_name")
  description         String?
  monthlyPrice        Int      @map("monthly_price") // In paise
  yearlyPrice         Int      @map("yearly_price") // In paise
  yearlyDiscount      Int      @default(0) @map("yearly_discount") // Percentage (e.g., 20 for 20%)
  credits             Int      // Credits per billing cycle
  features            String   @default("[]") // JSON array of feature strings
  razorpayMonthlyPlanId String? @map("razorpay_monthly_plan_id")
  razorpayYearlyPlanId  String? @map("razorpay_yearly_plan_id")
  isActive            Boolean  @default(true) @map("is_active")
  isDefault           Boolean  @default(false) @map("is_default") // Default plan for new users
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("subscription_plans")
}

// ============================================
// Subscription & Credit Models
// ============================================

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  tier                 String   @default("STARTER")
  status               String   @default("ACTIVE")
  billingCycle         String   @default("MONTHLY") @map("billing_cycle")
  creditsTotal         Int      @map("credits_total")
  creditsRemaining     Int      @map("credits_remaining")
  creditsRollover      Int      @default(0) @map("credits_rollover")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  razorpayCustomerId   String?  @map("razorpay_customer_id")
  razorpaySubId        String?  @map("razorpay_subscription_id")
  currentPeriodStart   DateTime @map("current_period_start")
  currentPeriodEnd     DateTime @map("current_period_end")
  canceledAt           DateTime? @map("canceled_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("subscriptions")
}

model CreditTransaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String
  amount      Int
  balance     Int
  description String?
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

// ============================================
// Platform Connection Models
// ============================================

model PlatformConnection {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  platform      String
  status        String    @default("CONNECTED")
  accountId     String?   @map("account_id")
  accountName   String?   @map("account_name")
  accessToken   String    @map("access_token")
  refreshToken  String?   @map("refresh_token")
  tokenExpiry   DateTime? @map("token_expiry")
  scopes        String    @default("[]")
  metadata      String?
  lastSyncAt    DateTime? @map("last_sync_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contents     Content[]
  adCampaigns  AdCampaign[]

  @@unique([userId, platform, accountId])
  @@map("platform_connections")
}

// ============================================
// Content Models
// ============================================

model Content {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  connectionId     String?   @map("connection_id")
  type             String
  status           String    @default("DRAFT")
  title            String?
  caption          String?
  body             String?
  hashtags         String    @default("[]")
  mediaUrls        String    @default("[]") @map("media_urls")
  thumbnailUrl     String?   @map("thumbnail_url")
  seoTitle         String?   @map("seo_title")
  seoDescription   String?   @map("seo_description")
  seoKeywords      String    @default("[]") @map("seo_keywords")
  aiPrompt         String?   @map("ai_prompt")
  aiMetadata       String?   @map("ai_metadata")
  platformPostId   String?   @map("platform_post_id")
  platformPostUrl  String?   @map("platform_post_url")
  scheduledAt      DateTime? @map("scheduled_at")
  publishedAt      DateTime? @map("published_at")
  creditsConsumed  Int       @default(0) @map("credits_consumed")
  errorMessage     String?   @map("error_message")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection PlatformConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  analytics  ContentAnalytics?
  media      ContentMedia[]

  @@index([userId, status])
  @@index([userId, scheduledAt])
  @@map("contents")
}

model ContentMedia {
  id          String   @id @default(uuid())
  contentId   String   @map("content_id")
  url         String
  type        String
  size        Int?
  width       Int?
  height      Int?
  duration    Int?
  altText     String?  @map("alt_text")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_media")
}

model ContentAnalytics {
  id           String   @id @default(uuid())
  contentId    String   @unique @map("content_id")
  impressions  Int      @default(0)
  reach        Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  shares       Int      @default(0)
  saves        Int      @default(0)
  clicks       Int      @default(0)
  engagement   Float    @default(0)
  lastSyncAt   DateTime @map("last_sync_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_analytics")
}

// ============================================
// Trending Topics Model
// ============================================

model TrendingTopic {
  id          String   @id @default(uuid())
  topic       String
  category    String?
  score       Float    @default(0)
  hashtags    String   @default("[]")
  keywords    String   @default("[]")
  region      String?
  source      String?
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([category, score])
  @@index([expiresAt])
  @@map("trending_topics")
}

// ============================================
// Audit Log Model
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ============================================
// API Credentials Model (for admin-managed secrets)
// ============================================

model ApiCredential {
  id          String   @id @default(uuid())
  key         String   @unique // e.g., "JASPER_API_KEY", "META_APP_ID"
  value       String   // Encrypted value
  description String?
  category    String?  // e.g., "jasper", "meta", "google", "razorpay"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("api_credentials")
}

// ============================================
// Payment Model (Razorpay transactions)
// ============================================

model Payment {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  subscriptionId    String?  @map("subscription_id")
  razorpayOrderId   String   @unique @map("razorpay_order_id")
  razorpayPaymentId String?  @map("razorpay_payment_id")
  razorpaySignature String?  @map("razorpay_signature")
  amount            Int      // In paise (smallest currency unit)
  currency          String   @default("INR")
  status            String   @default("CREATED") // CREATED, PAID, FAILED, REFUNDED
  planId            String?  @map("plan_id") // Which subscription plan
  metadata          String?  // JSON string for additional data
  failureReason     String?  @map("failure_reason")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@map("payments")
}

// ============================================
// Workspace & Page Builder Models
// ============================================

model Workspace {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  name          String   // Display name
  slug          String   @unique // Subdomain: slug.jeeper.app
  description   String?
  logo          String?  // URL to logo
  favicon       String?  // URL to favicon
  settings      String   @default("{}") // JSON: theme colors, fonts, etc.
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages         WorkspacePage[]
  posts         WorkspacePost[]
  menus         WorkspaceMenu[]

  @@map("workspaces")
}

model WorkspacePage {
  id            String    @id @default(uuid())
  workspaceId   String    @map("workspace_id")
  title         String
  slug          String    // URL path: /about, /services
  description   String?   // SEO description
  content       String    @default("[]") // JSON array of page sections/blocks
  htmlContent   String?   @map("html_content") // Rendered HTML with Tailwind classes
  cssContent    String?   @map("css_content") // Custom CSS if any
  status        String    @default("DRAFT") // DRAFT, PUBLISHED
  isHomePage    Boolean   @default(false) @map("is_home_page")
  seoTitle      String?   @map("seo_title")
  seoKeywords   String?   @map("seo_keywords")
  sortOrder     Int       @default(0) @map("sort_order")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@map("workspace_pages")
}

model WorkspacePost {
  id              String    @id @default(uuid())
  workspaceId     String    @map("workspace_id")
  title           String
  slug            String
  excerpt         String?
  content         String    @default("") // HTML content
  featuredImage   String?   @map("featured_image")
  status          String    @default("DRAFT") // DRAFT, PUBLISHED
  publishedAt     DateTime? @map("published_at")

  // WordPress sync
  wpPostId        String?   @map("wp_post_id") // WordPress post ID if synced
  wpSyncedAt      DateTime? @map("wp_synced_at")
  wpConnectionId  String?   @map("wp_connection_id") // PlatformConnection ID

  // SEO
  seoTitle        String?   @map("seo_title")
  seoDescription  String?   @map("seo_description")
  seoKeywords     String?   @map("seo_keywords")

  tags            String    @default("[]") // JSON array
  categories      String    @default("[]") // JSON array

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@map("workspace_posts")
}

model WorkspaceMenu {
  id            String   @id @default(uuid())
  workspaceId   String   @map("workspace_id")
  name          String   // e.g., "Main Menu", "Footer Menu"
  location      String   // HEADER, FOOTER, SIDEBAR
  items         String   @default("[]") // JSON array of menu items
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, location])
  @@index([workspaceId])
  @@map("workspace_menus")
}

// ============================================
// Ad Campaign Models (Google Ads + Meta Ads)
// ============================================

model AdCampaign {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  connectionId       String    @map("connection_id")
  platform           String    // GOOGLE_ADS, META_ADS
  platformCampaignId String?   @map("platform_campaign_id")
  name               String
  type               String    // SEARCH, DISPLAY, SHOPPING, AWARENESS, TRAFFIC, CONVERSIONS, LEADS
  objective          String?
  status             String    @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED, FAILED
  budget             Float     @default(0)
  budgetType         String    @default("DAILY") @map("budget_type") // DAILY, LIFETIME
  currency           String    @default("USD")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  targeting          String    @default("{}") // JSON: keywords, audiences, demographics, locations
  adCreatives        String    @default("[]") @map("ad_creatives") // JSON array of ad creative configs
  settings           String    @default("{}") // JSON: platform-specific settings
  creditsConsumed    Int       @default(0) @map("credits_consumed")
  lastSyncAt         DateTime? @map("last_sync_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection PlatformConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  metrics    AdCampaignMetric[]
  adGroups   AdGroup[]

  @@index([userId, platform, status])
  @@map("ad_campaigns")
}

model AdGroup {
  id                String   @id @default(uuid())
  campaignId        String   @map("campaign_id")
  platformAdGroupId String?  @map("platform_ad_group_id")
  name              String
  status            String   @default("ACTIVE")
  bidStrategy       String?  @map("bid_strategy")
  bidAmount         Float?   @map("bid_amount")
  keywords          String   @default("[]") // JSON array
  negativeKeywords  String   @default("[]") @map("negative_keywords")
  ads               String   @default("[]") // JSON array of ad objects
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@map("ad_groups")
}

model AdCampaignMetric {
  id             String   @id @default(uuid())
  campaignId     String   @map("campaign_id")
  date           DateTime
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  ctr            Float    @default(0)
  cpc            Float    @default(0)
  cost           Float    @default(0)
  conversions    Int      @default(0)
  conversionRate Float    @default(0) @map("conversion_rate")
  roas           Float?
  reach          Int      @default(0)
  cpa            Float?
  createdAt      DateTime @default(now()) @map("created_at")

  campaign AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId, date])
  @@map("ad_campaign_metrics")
}

// ============================================
// Lead Management / CRM Models
// ============================================

model Lead {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  email           String?
  phone           String?
  name            String
  company         String?
  source          String?   // GOOGLE_ADS, META_ADS, FORM, WEBSITE, MANUAL, EMAIL
  sourceId        String?   @map("source_id")
  stage           String    @default("NEW") // NEW, CONTACTED, QUALIFIED, PROPOSAL, NEGOTIATION, CONVERTED, LOST
  score           Int       @default(0)
  assignedTo      String?   @map("assigned_to")
  tags            String    @default("[]")
  customFields    String    @default("{}") @map("custom_fields")
  lastContactedAt DateTime? @map("last_contacted_at")
  convertedAt     DateTime? @map("converted_at")
  lostReason      String?   @map("lost_reason")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities LeadActivity[]
  notes      LeadNote[]

  @@index([userId, stage])
  @@index([userId, source])
  @@index([userId, score])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  type      String   // STAGE_CHANGE, EMAIL_SENT, CALL, NOTE, AD_CLICK, FORM_SUBMIT, PAGE_VIEW
  data      String   @default("{}") // JSON
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("lead_notes")
}

// ============================================
// Email Marketing Models
// ============================================

model EmailList {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  description  String?
  tags         String   @default("[]")
  contactCount Int      @default(0) @map("contact_count")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts  EmailContact[]
  campaigns EmailCampaign[]

  @@index([userId])
  @@map("email_lists")
}

model EmailContact {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  listId   String   @map("list_id")
  email    String
  name     String?
  status   String   @default("SUBSCRIBED") // SUBSCRIBED, UNSUBSCRIBED, BOUNCED
  metadata String   @default("{}") // JSON
  leadId   String?  @map("lead_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  list EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([listId, email])
  @@index([userId])
  @@map("email_contacts")
}

model EmailCampaign {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  listId        String?   @map("list_id")
  name          String
  subject       String
  previewText   String?   @map("preview_text")
  htmlContent   String    @default("") @map("html_content")
  type          String    @default("BROADCAST") // BROADCAST, SEQUENCE
  status        String    @default("DRAFT") // DRAFT, SCHEDULED, SENDING, SENT, FAILED
  scheduledAt   DateTime? @map("scheduled_at")
  sentAt        DateTime? @map("sent_at")
  totalSent     Int       @default(0) @map("total_sent")
  totalOpened   Int       @default(0) @map("total_opened")
  totalClicked  Int       @default(0) @map("total_clicked")
  totalBounced  Int       @default(0) @map("total_bounced")
  creditsConsumed Int     @default(0) @map("credits_consumed")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  list EmailList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("email_campaigns")
}

model EmailSequence {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  status      String   @default("DRAFT") // DRAFT, ACTIVE, PAUSED
  triggerType String   @default("MANUAL") @map("trigger_type") // MANUAL, LEAD_STAGE, FORM_SUBMIT
  steps       String   @default("[]") // JSON array of {delayDays, subject, htmlContent}
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_sequences")
}

// ============================================
// Design / Flyer Models
// ============================================

model Design {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  template        String?
  category        String?  // SOCIAL_POST, FLYER, BANNER, POSTER, STORY, AD
  htmlContent     String   @default("") @map("html_content")
  cssContent      String?  @map("css_content")
  width           Int      @default(1080)
  height          Int      @default(1080)
  sizePreset      String?  @map("size_preset") // INSTAGRAM_POST, FACEBOOK_COVER, A4_FLYER, etc.
  outputUrl       String?  @map("output_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  creditsConsumed Int      @default(0) @map("credits_consumed")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("designs")
}

// ============================================
// Video Project Models
// ============================================

model VideoProject {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  type            String   // PRODUCT_SHOWCASE, TESTIMONIAL, EXPLAINER, SOCIAL_AD, PROMO
  provider        String   @default("RUNWAY") // RUNWAY, HEYGEN
  status          String   @default("DRAFT") // DRAFT, GENERATING, COMPLETED, FAILED
  prompt          String?
  scriptContent   String?  @map("script_content")
  settings        String   @default("{}") // JSON: aspect ratio, duration, style
  providerJobId   String?  @map("provider_job_id")
  videoUrl        String?  @map("video_url")
  thumbnailUrl    String?  @map("thumbnail_url")
  duration        Int?     // seconds
  creditsConsumed Int      @default(0) @map("credits_consumed")
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("video_projects")
}

// ============================================
// Google Analytics Snapshots
// ============================================

model AnalyticsSnapshot {
  id                 String   @id @default(uuid())
  userId             String   @map("user_id")
  connectionId       String   @map("connection_id")
  propertyId         String   @map("property_id")
  date               DateTime
  sessions           Int      @default(0)
  users              Int      @default(0)
  newUsers           Int      @default(0) @map("new_users")
  pageViews          Int      @default(0) @map("page_views")
  bounceRate         Float    @default(0) @map("bounce_rate")
  avgSessionDuration Float    @default(0) @map("avg_session_duration")
  trafficSources     String   @default("{}") @map("traffic_sources")
  topPages           String   @default("[]") @map("top_pages")
  conversions        Int      @default(0)
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId, date])
  @@index([userId, date])
  @@map("analytics_snapshots")
}
